{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",

    "types": ["node"],

    "sourceMap": true,

    "strict": true,

    "esModuleInterop": true,

    "isolatedModules": true,

    "skipLibCheck": true,

    "verbatimModuleSyntax": false
  }
}